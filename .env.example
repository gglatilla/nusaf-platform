# Database
# For local development with standard PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nusaf_platform"
# For Prisma's local development server:
DATABASE_URL="prisma+postgres://..."

# NextAuth - IMPORTANT: Generate a secure random string for production
# You can generate one using: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Application
NODE_ENV="development"
