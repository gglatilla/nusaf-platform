# Database
# For local development with standard PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nusaf_platform"
# For Prisma's local development server:
DATABASE_URL="prisma+postgres://..."

# NextAuth - IMPORTANT: Generate a secure random string for production
# You can generate one using: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3001"

# Application
NODE_ENV="development"

# Staging flag - IMPORTANT for SEO protection
# Set to "true" on staging (*.nusaf.net) to block search engine indexing
# Set to "false" only on production (*.nusaf.co.za) when ready to go live
NEXT_PUBLIC_IS_STAGING="true"

# Cross-app URLs (for linking between marketing and webapp)
NEXT_PUBLIC_WEBAPP_URL="http://localhost:3001"
NEXT_PUBLIC_MARKETING_URL="http://localhost:3000"
